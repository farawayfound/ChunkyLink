# -*- coding: utf-8 -*-
"""Server-side paths and settings for the MCP server — generated by Ansible."""

JSON_KB_DIR          = "{{ srv_dir }}/JSON"
DPSTRIAGE_CSV_DIR    = "{{ dpstriage_csv_dir }}"
POSTRCA_CSV_DIR      = "{{ postrca_csv_dir }}"
REPO_DIR         = "{{ srv_dir }}"
INDEXER_SCRIPT   = "{{ srv_dir }}/indexers/build_index.py"
# Per-user bearer tokens for identity logging.
# Tokens matching "vporag-P<7digits>" are auto-registered on first use — no admin action needed.
# Add entries here only to pre-seed tokens or assign a custom display name.
# REQUIRE_AUTH = True blocks anonymous requests (returns 401).
AUTH_TOKENS = {
{% for token, name in auth_tokens.items() %}
    "{{ token }}": "{{ name }}",
{% endfor %}
}
REQUIRE_AUTH = {{ require_auth | lower }}

# Jira SQL connection — ODBC Driver 18 (only version available on Ubuntu 24.04)
JIRA_SQL_SERVER   = "{{ jira_sql_server }}"
JIRA_SQL_DATABASE = "{{ jira_sql_database }}"
JIRA_SQL_DRIVER   = "{{ odbc_driver_name }}"

# Keyring backend for headless Linux (avoids D-Bus dependency)
KEYRING_BACKEND = "keyrings.alt.file.PlaintextKeyring"

# Jira source strategy — "mysql" (local, always reachable) | "sql" (Charter VPN required) | "csv"
# Default is mysql; switch to sql only when connected to Charter VPN.
JIRA_PRIMARY_SOURCE      = "{{ jira_primary_source }}"
JIRA_SEARCH_BOTH_SOURCES = {{ jira_search_both_sources | lower }}

# MySQL — local Jira ticket store (always reachable, no VPN required)
MYSQL_HOST = "localhost"
MYSQL_USER = "{{ mysql_user }}"
MYSQL_PASS = "{{ mysql_pass }}"
MYSQL_DB   = "{{ mysql_db }}"

# MCP output cap — hard ceiling on chunks returned per search_kb call.
# Measured p90 slimmed chunk size = ~4,000 chars; 15 chunks ≈ 60K chars worst-case.
MCP_MAX_RESULTS = {{ mcp_max_results }}
