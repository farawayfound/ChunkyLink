# ============================================================
# Nanobot Worker — Environment Configuration
# ============================================================
# Copy to .env.nanobot and fill in the values below.
# The live .env.nanobot is NOT tracked in git and is NOT touched by any
# deploy script. Your tuned values survive git pull / docker rebuilds.
# Full split-host (Mac mini + nanobot) runbook: docs/library-nanobot-troubleshooting.md
# ============================================================

# --- REQUIRED: replace <MAC_IP> with the Mac mini's LAN IP ---
# Find it on the Mac: ipconfig getifaddr en0
# Docker on Linux CANNOT resolve mDNS names like macmini.local — always use the IP.

# Redis — MUST be reachable from *inside* the worker container (not from the Mac shell).
# NEVER use localhost/127.0.0.1 here when the worker runs in Docker: that is the container itself → crash loop.
# Use the Mac mini's *actual* Wi‑Fi/Ethernet IP (same subnet as nanobot) and the same DB index as the backend .env.
# If logs show errno 113 / EHOSTUNREACH: wrong IP, no route, or firewall.
# If nc/redis-cli shows "Connection refused": Redis on the Mac is not listening on the LAN interface —
# edit redis.conf: bind 0.0.0.0 (or include 192.168.x.x), restart Redis; allow TCP 6379 in the Mac firewall.
# Test from nanobot: nc -zv <mac-ip> 6379   (should say "succeeded" before the worker will connect)
REDIS_URL=redis://<MAC_IP>:6379/0

# M1 backend URL for delivering completed research.
# NEVER use a .local mDNS hostname here — it will NOT resolve inside the Linux Docker container.
# Port must match the backend's listen port (see backend/.env PORT; Mac mini deploy often uses 8765).
M1_BASE_URL=http://<MAC_IP>:8765

# Must match the NANOBOT_API_KEY set in the Mac backend's .env.
NANOBOT_API_KEY=

# Ollama — MUST match where the worker process can reach Ollama (see docker-compose.nanobot.yml).
# Same compose stack (default): use the Docker service name:
#   OLLAMA_BASE_URL=http://ollama:11434
# If the worker cannot use that hostname, or Ollama is bound on the host LAN only, use the host IP:
#   OLLAMA_BASE_URL=http://192.168.0.152:11434
# Wrong URL often yields HTTP 404 on POST /api/generate (Ollama uses 404 for unknown routes or missing model tags).
OLLAMA_BASE_URL=http://ollama:11434
# Must match an entry from `ollama list` / GET /api/tags — wrong tag => HTTP 404 on /api/generate
OLLAMA_MODEL=gemma4:26b

# Per-request timeout for Ollama. Streaming is on, so this applies per-token
# (not to the whole response). 3600s is generous.
OLLAMA_TIMEOUT=3600

# KV cache size. On a 32 GB host with gemma4:26b (~16 GB weights) and a 30 GB
# docker mem_limit, 24576 (24k) is the largest value that reliably fits without
# swap-thrash. 65536+ will OOM / silently stall the model load.
OLLAMA_NUM_CTX=24576

# Crawling limits
MAX_SEARCH_RESULTS=10
MAX_CONCURRENT_SCRAPES=4
SCRAPE_TIMEOUT=30

# Worker identity (used in Redis consumer group)
WORKER_ID=nanobot-1

LOG_LEVEL=INFO
